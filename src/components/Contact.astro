---
/**
 * Contact.astro — "Let's Build Something" contact section
 * Two-column layout: form (60%) + contact info card (40%).
 * Stacks vertically on mobile.
 * Uses global utility classes: gradient-text, glass-card, comment-prefix.
 */
---

<section id="contact" class="py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Section Heading -->
    <h2
      class="mb-4 text-center text-3xl font-bold md:text-4xl"
      style="font-family: 'JetBrains Mono', 'Fira Code', monospace;"
    >
      <span class="comment-prefix">// </span><span class="gradient-text">Let's Build Something</span>
    </h2>

    <!-- Section Intro -->
    <p
      class="mx-auto mb-16 max-w-2xl text-center text-[#8b949e]"
      style="font-family: 'Outfit', sans-serif;"
    >
      Tell me what's eating your time or budget. I'll tell you if AI can fix it
      — and exactly how I'd build the solution.
    </p>

    <!-- Two-Column Layout -->
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[3fr_2fr]">
      <!-- Left Column: Contact Form -->
      <div>
        <div class="glass-card p-8">
          <!-- Replace action="#" with your actual Formspree endpoint, e.g. action="https://formspree.io/f/YOUR_ID" -->
          <form action="#" method="POST" class="space-y-6">
            <!-- Name -->
            <div>
              <label
                for="contact-name"
                class="mb-2 block text-sm text-[#8b949e]"
                style="font-family: 'Outfit', sans-serif;"
              >
                Name <span class="text-[#8b5cf6]">*</span>
              </label>
              <input
                type="text"
                id="contact-name"
                name="name"
                required
                class="contact-input w-full rounded-xl border border-white/10 px-4 py-3 text-[#e6edf3] placeholder-[#8b949e]/50 outline-none"
                style="background: rgba(255,255,255,0.05); font-family: 'Outfit', sans-serif; transition: border-color 200ms ease, box-shadow 200ms ease;"
              />
            </div>

            <!-- Email -->
            <div>
              <label
                for="contact-email"
                class="mb-2 block text-sm text-[#8b949e]"
                style="font-family: 'Outfit', sans-serif;"
              >
                Email <span class="text-[#8b5cf6]">*</span>
              </label>
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                class="contact-input w-full rounded-xl border border-white/10 px-4 py-3 text-[#e6edf3] placeholder-[#8b949e]/50 outline-none"
                style="background: rgba(255,255,255,0.05); font-family: 'Outfit', sans-serif; transition: border-color 200ms ease, box-shadow 200ms ease;"
              />
            </div>

            <!-- Company (Optional) -->
            <div>
              <label
                for="contact-company"
                class="mb-2 block text-sm text-[#8b949e]"
                style="font-family: 'Outfit', sans-serif;"
              >
                Company
              </label>
              <input
                type="text"
                id="contact-company"
                name="company"
                class="contact-input w-full rounded-xl border border-white/10 px-4 py-3 text-[#e6edf3] placeholder-[#8b949e]/50 outline-none"
                style="background: rgba(255,255,255,0.05); font-family: 'Outfit', sans-serif; transition: border-color 200ms ease, box-shadow 200ms ease;"
              />
            </div>

            <!-- Budget Range -->
            <div>
              <label
                for="contact-budget"
                class="mb-2 block text-sm text-[#8b949e]"
                style="font-family: 'Outfit', sans-serif;"
              >
                Approximate Budget
              </label>
              <select
                id="contact-budget"
                name="budget"
                class="contact-input w-full rounded-xl border border-white/10 px-4 py-3 text-[#e6edf3] outline-none"
                style="background: rgba(255,255,255,0.05); font-family: 'Outfit', sans-serif; transition: border-color 200ms ease, box-shadow 200ms ease;"
              >
                <option value="" style="background: #0f0a1e;">Not sure yet</option>
                <option value="under-2k" style="background: #0f0a1e;">Under $2,000</option>
                <option value="2k-5k" style="background: #0f0a1e;">$2,000 – $5,000</option>
                <option value="5k-10k" style="background: #0f0a1e;">$5,000 – $10,000</option>
                <option value="10k-25k" style="background: #0f0a1e;">$10,000 – $25,000</option>
                <option value="25k-plus" style="background: #0f0a1e;">$25,000+</option>
              </select>
            </div>

            <!-- Message -->
            <div>
              <label
                for="contact-message"
                class="mb-2 block text-sm text-[#8b949e]"
                style="font-family: 'Outfit', sans-serif;"
              >
                Message <span class="text-[#8b5cf6]">*</span>
              </label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="5"
                placeholder="What manual work or agency costs would you like to eliminate?"
                class="contact-input w-full resize-y rounded-xl border border-white/10 px-4 py-3 text-[#e6edf3] placeholder-[#8b949e]/50 outline-none"
                style="background: rgba(255,255,255,0.05); font-family: 'Outfit', sans-serif; transition: border-color 200ms ease, box-shadow 200ms ease;"
              ></textarea>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              class="w-full cursor-pointer rounded-full px-8 py-4 text-base font-semibold text-white transition-transform duration-200 hover:scale-[1.02]"
              style="background: linear-gradient(135deg, #8b5cf6, #06b6d4); font-family: 'Outfit', sans-serif;"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>

      <!-- Right Column: Contact Info Card -->
      <div>
        <div class="glass-card p-8">
          <!-- Contact Methods -->
          <div class="space-y-5">
            <!-- Email -->
            <a
              href="mailto:prekoconsult@gmail.com"
              class="contact-link flex items-center gap-3 text-[#8b949e]"
              style="font-family: 'Outfit', sans-serif; transition: color 200ms ease;"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#3b82f6"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="flex-shrink-0"
                aria-hidden="true"
              >
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <path d="M22 7l-10 7L2 7" />
              </svg>
              <span>prekoconsult@gmail.com</span>
            </a>

            <!-- Phone -->
            <a
              href="tel:+19053349282"
              class="contact-link flex items-center gap-3 text-[#8b949e]"
              style="font-family: 'Outfit', sans-serif; transition: color 200ms ease;"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#3b82f6"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="flex-shrink-0"
                aria-hidden="true"
              >
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" />
              </svg>
              <span>905-334-9282</span>
            </a>

            <!-- LinkedIn -->
            <a
              href="https://www.linkedin.com/in/gregkowalczyk/"
              target="_blank"
              rel="noopener noreferrer"
              class="contact-link flex items-center gap-3 text-[#8b949e]"
              style="font-family: 'Outfit', sans-serif; transition: color 200ms ease;"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#3b82f6"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="flex-shrink-0"
                aria-hidden="true"
              >
                <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z" />
                <rect x="2" y="9" width="4" height="12" />
                <circle cx="4" cy="4" r="2" />
              </svg>
              <span>linkedin.com/in/gregkowalczyk</span>
            </a>

            <!-- X (Twitter) -->
            <a
              href="https://x.com/kowalcg"
              target="_blank"
              rel="noopener noreferrer"
              class="contact-link flex items-center gap-3 text-[#8b949e]"
              style="font-family: 'Outfit', sans-serif; transition: color 200ms ease;"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="#3b82f6"
                class="flex-shrink-0"
                aria-hidden="true"
              >
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
              <span>x.com/kowalcg</span>
            </a>

            <!-- Facebook -->
            <a
              href="https://www.facebook.com/Kowalcg/"
              target="_blank"
              rel="noopener noreferrer"
              class="contact-link flex items-center gap-3 text-[#8b949e]"
              style="font-family: 'Outfit', sans-serif; transition: color 200ms ease;"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#3b82f6"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="flex-shrink-0"
                aria-hidden="true"
              >
                <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" />
              </svg>
              <span>facebook.com/Kowalcg</span>
            </a>
          </div>

          <!-- Divider -->
          <div class="my-6" style="border-top: 1px solid rgba(255,255,255,0.08);"></div>

          <!-- Location -->
          <p
            class="text-sm text-[#8b949e]"
            style="font-family: 'Outfit', sans-serif;"
          >
            Based in Oakville, Ontario — serving the Greater Toronto Area and beyond
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-input:focus,
  select.contact-input:focus {
    border-color: #06b6d4;
    box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.2);
  }

  select.contact-input option {
    background: #0f0a1e;
    color: #e6edf3;
  }

  .contact-link:hover {
    color: #e6edf3;
  }
</style>

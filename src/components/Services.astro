---
/**
 * Services.astro — "What I Build" service cards section
 * 4 cards in a 2x2 grid with glass-card hover effects.
 * Uses global utility classes: gradient-text, glass-card, glass-card-hover, fade-in-up, comment-prefix.
 */

const services = [
  {
    title: "Custom AI Tools",
    body: "Prompt generators, content systems, analytics dashboards — built for your specific business. Not off-the-shelf SaaS. Custom tools you own and control.",
    proof: "Built Content Creator PRO for a client in 6 weeks. Running in production daily.",
    icon: "terminal",
    slug: "custom-ai-tools",
  },
  {
    title: "E-Commerce AI Systems",
    body: "Product content at scale, inventory automation, multi-channel optimization. Tested on my own brands first — two e-commerce businesses I've built and run since 2014, using AI tools I built myself.",
    proof: "5-10x content volume. 90% faster production. Same or better quality.",
    icon: "cart",
    slug: "ecommerce-ai",
  },
  {
    title: "Marketing Automation",
    body: "Email sequences, social content workflows, ad optimization, customer journey orchestration. Replace repetitive manual work with systems that run while you sleep.",
    proof: "Replaced $75K-$125K in agency and freelancer costs with $2K in tools.",
    icon: "workflow",
    slug: "marketing-automation",
  },
  {
    title: "AI Readiness Assessment",
    body: "Not sure where to start with AI? I audit your operations, identify the highest-ROI automation opportunities, and build a practical implementation roadmap. Then I build it.",
    proof: "Local retail client: $537K business mapped to $1M+ growth trajectory in 6 weeks.",
    icon: "compass",
    slug: "ai-assessment",
  },
  {
    title: "Digital Launch & Growth",
    body: "Not online yet? I coach product businesses through Amazon, Shopify, and Walmart setup — and service businesses (electricians, landscapers, trades) through website, local SEO, and LLM optimization. You run the business. I build the AI layer that scales it.",
    proof: "Two brands launched from zero. Local retail client: offline shop to full digital presence in 6 weeks.",
    icon: "rocket",
    slug: "digital-launch",
  },
  {
    title: "Product Research & Validation",
    body: "Mechanical engineer turned e-commerce operator — I evaluate products differently. I combine 11 years of hands-on product launches with deep engineering analysis and AI-powered tools (Data Dive, Jungle Scout, web scraping) to surface real demand, stress-test margins, and validate physical and market viability before a dollar goes to inventory.",
    proof: "Not just market research — structural evaluation. Built custom AI research systems for clients to do this at scale.",
    icon: "microscope",
    slug: "product-research",
  },
];
---

<section id="services" class="py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Section Heading -->
    <h2
      class="text-center text-3xl font-bold md:text-4xl"
      style="font-family: 'JetBrains Mono', 'Fira Code', monospace;"
    >
      <span class="comment-prefix">// </span><span class="gradient-text">What I Build</span>
    </h2>

    <!-- Section Intro -->
    <p
      class="mx-auto mt-4 max-w-2xl text-center text-[#8b949e] mb-16"
      style="font-family: 'Outfit', sans-serif;"
    >
      Every project follows one rule: you get a working system, not a strategy
      deck. I code it, deploy it, and train you to use it.
    </p>

    <!-- Service Cards Grid -->
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {services.map((service) => (
        <div
          id={service.slug}
          class="fade-in-up glass-card glass-card-hover overflow-hidden group p-8"
        >
          {/* Icon */}
          <div
            class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg"
            style="background: linear-gradient(135deg, #8b5cf6, #06b6d4);"
          >
            {service.icon === "terminal" && (
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <polyline points="4 17 10 11 4 5" />
                <line x1="12" y1="19" x2="20" y2="19" />
              </svg>
            )}
            {service.icon === "cart" && (
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="9" cy="21" r="1" />
                <circle cx="20" cy="21" r="1" />
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
              </svg>
            )}
            {service.icon === "workflow" && (
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <polyline points="16 3 21 3 21 8" />
                <line x1="4" y1="20" x2="21" y2="3" />
                <polyline points="21 16 21 21 16 21" />
                <line x1="15" y1="15" x2="21" y2="21" />
                <line x1="4" y1="4" x2="9" y2="9" />
              </svg>
            )}
            {service.icon === "compass" && (
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10" />
                <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76" />
              </svg>
            )}
            {service.icon === "rocket" && (
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 00-2.91-.09z"/>
                <path d="M12 15l-3-3a22 22 0 012-3.95A12.88 12.88 0 0122 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 01-4 2z"/>
                <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>
                <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
              </svg>
            )}
            {service.icon === "microscope" && (
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M6 18h8"/>
                <path d="M3 22h18"/>
                <path d="M14 22a7 7 0 1 0 0-14h-1"/>
                <path d="M9 14h2"/>
                <path d="M9 12a2 2 0 0 1-2-2V6h6v4a2 2 0 0 1-2 2Z"/>
                <path d="M12 6V3a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3"/>
              </svg>
            )}
          </div>

          {/* Title */}
          <h3
            class="mb-3 text-xl text-[#e6edf3]"
            style="font-family: 'JetBrains Mono', 'Fira Code', monospace;"
          >
            {service.title}
          </h3>

          {/* Body */}
          <p
            class="mb-4 leading-relaxed text-[#8b949e]"
            style="font-family: 'Outfit', sans-serif;"
          >
            {service.body}
          </p>

          {/* Proof Line */}
          <p
            class="text-sm italic text-[#06b6d4]"
            style="font-family: 'Outfit', sans-serif;"
          >
            {service.proof}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

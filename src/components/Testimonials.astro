---
/**
 * Testimonials.astro — Client testimonials / social proof section
 * Three glass cards in a responsive grid.
 * TODO: Replace placeholder content with real client quotes when available.
 */

const testimonials = [
  {
    // TODO: Replace with real testimonial
    quote: "Greg built an AI content system that replaced work we were paying $3,000/month for. The output quality is better and we don't wait days for turnaround anymore.",
    name: "Client Name",
    title: "Business Owner",
    company: "Company Name",
    placeholder: true,
  },
  {
    // TODO: Replace with real testimonial
    quote: "We had no visibility into our daily numbers. Greg set up an automated reporting dashboard in a weekend. Now I see everything by 6am without anyone pulling a single spreadsheet.",
    name: "Client Name",
    title: "E-Commerce Operator",
    company: "Company Name",
    placeholder: true,
  },
  {
    // TODO: Replace with real testimonial
    quote: "I expected a strategy document. I got a working system. That's the difference — Greg actually builds the thing, not just the plan.",
    name: "Client Name",
    title: "Founder",
    company: "Company Name",
    placeholder: true,
  },
];
---

<section class="py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Section Heading -->
    <h2
      class="mb-4 text-center text-3xl font-bold md:text-4xl"
      style="font-family: 'JetBrains Mono', 'Fira Code', monospace;"
    >
      <span class="comment-prefix">// </span><span class="gradient-text">What Clients Say</span>
    </h2>
    <p
      class="mx-auto mb-16 max-w-2xl text-center text-[#8b949e]"
      style="font-family: 'Outfit', sans-serif;"
    >
      Results from businesses that made the switch from agencies to AI systems.
    </p>

    <!-- Testimonial Grid -->
    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {testimonials.map((t) => (
        <div class="fade-in-up glass-card flex flex-col p-8">
          <!-- Quote mark -->
          <div
            class="mb-4 text-4xl leading-none"
            style="color: rgba(139, 92, 246, 0.4); font-family: Georgia, serif;"
            aria-hidden="true"
          >
            &ldquo;
          </div>

          <!-- Quote text -->
          <p
            class="mb-6 flex-1 leading-relaxed"
            style="font-family: 'Outfit', sans-serif; color: #8b949e;"
          >
            {t.quote}
          </p>

          <!-- Attribution -->
          <div class="flex items-center gap-3">
            <!-- Avatar placeholder -->
            <div
              class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full"
              style="background: linear-gradient(135deg, rgba(139,92,246,0.3), rgba(6,182,212,0.3)); border: 1px solid rgba(255,255,255,0.1);"
            >
              <span
                class="text-xs font-semibold"
                style="color: #8b949e; font-family: 'JetBrains Mono', monospace;"
              >
                {t.name.split(' ').map((n: string) => n[0]).join('').slice(0, 2)}
              </span>
            </div>

            <!-- Name and title -->
            <div>
              <p
                class="font-semibold"
                style="font-family: 'Outfit', sans-serif; color: #e6edf3; font-size: 0.875rem;"
              >
                {t.name}
              </p>
              <p
                class="text-xs"
                style="font-family: 'Outfit', sans-serif; color: #8b949e;"
              >
                {t.title}{t.company !== "Company Name" ? `, ${t.company}` : ""}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

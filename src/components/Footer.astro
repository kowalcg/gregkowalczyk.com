---
/**
 * Footer.astro — Simple site footer
 * Copyright, LinkedIn icon, and tagline. Stacks vertically on mobile.
 */
---

<footer style="background-color: #0f0a1e; border-top: 1px solid rgba(255,255,255,0.08);">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 py-8 sm:flex-row">
    <!-- Left: Copyright -->
    <p
      class="text-sm text-[#8b949e]"
      style="font-family: 'Outfit', sans-serif;"
    >
      &copy; 2026 Greg Kowalczyk. Built with Astro.
    </p>

    <!-- Center: Social Icons -->
    <div class="flex items-center gap-4">
      <a
        href="https://www.linkedin.com/in/gregkowalczyk/"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-social text-[#8b949e]"
        aria-label="Greg Kowalczyk on LinkedIn"
        style="transition: color 200ms ease;"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z" />
          <rect x="2" y="9" width="4" height="12" />
          <circle cx="4" cy="4" r="2" />
        </svg>
      </a>
      <a
        href="https://x.com/kowalcg"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-social text-[#8b949e]"
        aria-label="Greg Kowalczyk on X"
        style="transition: color 200ms ease;"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
        </svg>
      </a>
      <a
        href="https://www.facebook.com/Kowalcg/"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-social text-[#8b949e]"
        aria-label="Greg Kowalczyk on Facebook"
        style="transition: color 200ms ease;"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" />
        </svg>
      </a>
    </div>

    <!-- Right: Tagline -->
    <p
      class="text-sm text-[#8b949e]"
      style="font-family: 'Outfit', sans-serif;"
    >
      AI & Digital Growth Consultant &middot; Oakville, Ontario
    </p>
  </div>
</footer>

<style>
  .footer-social:hover {
    color: #e6edf3;
  }
</style>
